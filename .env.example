# ================================================================
# PostgreSQL
# ================================================================
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=postgres

# Для локального подключения (Alembic, venv, psql)
# Внешний порт из docker-compose.yml
DB_HOST=localhost
DB_PORT=5430

# Для Docker (внутри контейнера)
DB_HOST_DOCKER=postgres
DB_PORT_DOCKER=5432

# ================================================================
# JWT
# ================================================================
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================================================
# ML Services
# ================================================================
HF_API_KEY=your_hf_token
OPENAI_API_KEY=your_openai_token
OPENAI_BASE_URL=https://api.openai.com/v1
PYANNOTE_MODEL_PATH=/app/models/pyannote

# ================================================================
# Vector DB (RAG)
# ================================================================
VECTOR_DB=qdrant
QDRANT_HOST=qdrant
QDRANT_INTERNAL_PORT=6333